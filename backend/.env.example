# VeVit Portal Backend Environment Variables

# Server
PORT=4000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=vevit
DB_PASS=your_password
DB_NAME=vevit_portal

# Auth
JWT_SECRET=your_jwt_secret_key

# Internal API shared secret (for activity ingest from other subdomains)
INTERNAL_SECRET=your_internal_secret

# SMTP (for contact form + newsletter)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=info@vevit.fun

# Cloudflare Turnstile
TURNSTILE_SECRET=your_turnstile_secret_key

# Owner email for contact form
OWNER_EMAIL=info@vevit.fun

# CORS
CORS_ORIGIN=https://vevit.fun,http://localhost:3000